migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
**/Flutter/ephemeral/
**/.symlinks/
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/
/ios/Pods/
/macos/Pods/
/output/
/third_party/

# Local vendored dependency patches
/vendor/**/.dart_tool/
/vendor/**/.flutter-plugins-dependencies
/vendor/**/example/
/vendor/**/test/
/vendor/**/pubspec.lock
/vendor/**/analysis_options.yaml
/vendor/**/README*
/vendor/**/CHANGELOG*
/vendor/**/CONTRIBUTING*
/vendor/**/*.iml

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release
